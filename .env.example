# ── AquaMind Environment Config ──────────────────────────────────────────────

# App
APP_NAME=AquaMind
APP_ENV=development                 # development | production
APP_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
DEBUG=true

# API
API_HOST=0.0.0.0
API_PORT=8000

# Database (PostgreSQL + TimescaleDB)
DATABASE_URL=postgresql+asyncpg://aquamind:password@localhost:5432/aquamind
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis
REDIS_URL=redis://localhost:6379/0

# MQTT Broker
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_BROKER_PORT_TLS=8883
MQTT_USERNAME=aquamind
MQTT_PASSWORD=change-me
MQTT_CLIENT_ID=aquamind-server
MQTT_USE_TLS=false
MQTT_KEEPALIVE=60

# MQTT Topics
MQTT_TOPIC_SENSORS=aqua/+/sensors      # aqua/{farm_id}/sensors
MQTT_TOPIC_ACTIONS=aqua/{farm_id}/actions
MQTT_TOPIC_STATUS=aqua/+/status

# AI — Managed (AquaMind's key)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-5
AI_MAX_TOKENS=1024
AI_ANALYSIS_INTERVAL=30              # seconds between AI analyses

# Auth
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24h
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Notifications
SENDGRID_API_KEY=SG....
NOTIFICATION_FROM_EMAIL=alerts@aquamind.io

# Sensor thresholds (global fallback, overridden per species)
DEFAULT_DO_MIN=5.0
DEFAULT_PH_MIN=6.0
DEFAULT_PH_MAX=9.0
DEFAULT_NH3_MAX=1.0
DEFAULT_TEMP_MIN=10.0
DEFAULT_TEMP_MAX=35.0
